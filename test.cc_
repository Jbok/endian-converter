#include <gtest/gtest.h>

extern "C" {
#include "complex_struct.h"
}

TEST(GcciEndianConverterDfcbTest, network_address_t_id)
{
    uint8_t big_endian_raw_network_address_t_id[] = 
    {
        0xA1, 0xB2, 0xC3, 0xD4, //uint32_t ip_address;
        0xA1, 0xB2, //uint16_t port;
        0xA1, 0xB2, //uint16_t protocol;
    };

    uint8_t little_endian_raw_network_address_t_id[] = 
    {
        0xD4, 0xC3, 0xB2, 0xA1, //uint32_t ip_address;
        0xB2, 0xA1, //uint16_t port;
        0xB2, 0xA1, //uint16_t protocol;
    };

    EXPECT_EQ(sizeof(big_endian_raw_network_address_t_id),
              sizeof(network_address_t));
    EXPECT_EQ(sizeof(little_endian_raw_network_address_t_id),
              sizeof(network_address_t));

    messageHdr_type *pBigEndianMsgHdr = (messageHdr_type *)big_endian_raw_network_address_t_id;
    messageHdr_type *pLittleEndianMsgHdr = (messageHdr_type *)little_endian_raw_network_address_t_id;
    pBigEndianMsgHdr ->msgType = htons(network_address_t_id);
    pLittleEndianMsgHdr->msgType = (network_address_t_id);

    Gcci_EndianH2N(little_endian_raw_network_address_t_id, sizeof(network_address_t));

    EXPECT_EQ(0, memcmp(big_endian_raw_network_address_t_id,
                        little_endian_raw_network_address_t_id,
                        sizeof(little_endian_raw_network_address_t_id)));
}

TEST(GcciEndianConverterDfcbTest, timestamp_t_id)
{
    uint8_t big_endian_raw_timestamp_t_id[] = 
    {
        0xA1, 0xB2, 0xC3, 0xD4, //uint32_t seconds;
        0xA1, 0xB2, 0xC3, 0xD4, //uint32_t microseconds;
        0xA1, 0xB2, //uint16_t timezone;
    };

    uint8_t little_endian_raw_timestamp_t_id[] = 
    {
        0xD4, 0xC3, 0xB2, 0xA1, //uint32_t seconds;
        0xD4, 0xC3, 0xB2, 0xA1, //uint32_t microseconds;
        0xB2, 0xA1, //uint16_t timezone;
    };

    EXPECT_EQ(sizeof(big_endian_raw_timestamp_t_id),
              sizeof(timestamp_t));
    EXPECT_EQ(sizeof(little_endian_raw_timestamp_t_id),
              sizeof(timestamp_t));

    messageHdr_type *pBigEndianMsgHdr = (messageHdr_type *)big_endian_raw_timestamp_t_id;
    messageHdr_type *pLittleEndianMsgHdr = (messageHdr_type *)little_endian_raw_timestamp_t_id;
    pBigEndianMsgHdr ->msgType = htons(timestamp_t_id);
    pLittleEndianMsgHdr->msgType = (timestamp_t_id);

    Gcci_EndianH2N(little_endian_raw_timestamp_t_id, sizeof(timestamp_t));

    EXPECT_EQ(0, memcmp(big_endian_raw_timestamp_t_id,
                        little_endian_raw_timestamp_t_id,
                        sizeof(little_endian_raw_timestamp_t_id)));
}

TEST(GcciEndianConverterDfcbTest, sensor_data_t_id)
{
    uint8_t big_endian_raw_sensor_data_t_id[] = 
    {
        0xA1, 0xB2, 0xC3, 0xD4, //uint32_t sensor_id;
        0xA1, 0xB2, //uint16_t temperature;
        0xA1, 0xB2, //uint16_t humidity;
        0xA1, 0xB2, 0xC3, 0xD4, //uint32_t pressure;
        0xA1, 0xB2, //uint16_t status;
    };

    uint8_t little_endian_raw_sensor_data_t_id[] = 
    {
        0xD4, 0xC3, 0xB2, 0xA1, //uint32_t sensor_id;
        0xB2, 0xA1, //uint16_t temperature;
        0xB2, 0xA1, //uint16_t humidity;
        0xD4, 0xC3, 0xB2, 0xA1, //uint32_t pressure;
        0xB2, 0xA1, //uint16_t status;
    };

    EXPECT_EQ(sizeof(big_endian_raw_sensor_data_t_id),
              sizeof(sensor_data_t));
    EXPECT_EQ(sizeof(little_endian_raw_sensor_data_t_id),
              sizeof(sensor_data_t));

    messageHdr_type *pBigEndianMsgHdr = (messageHdr_type *)big_endian_raw_sensor_data_t_id;
    messageHdr_type *pLittleEndianMsgHdr = (messageHdr_type *)little_endian_raw_sensor_data_t_id;
    pBigEndianMsgHdr ->msgType = htons(sensor_data_t_id);
    pLittleEndianMsgHdr->msgType = (sensor_data_t_id);

    Gcci_EndianH2N(little_endian_raw_sensor_data_t_id, sizeof(sensor_data_t));

    EXPECT_EQ(0, memcmp(big_endian_raw_sensor_data_t_id,
                        little_endian_raw_sensor_data_t_id,
                        sizeof(little_endian_raw_sensor_data_t_id)));
}

TEST(GcciEndianConverterDfcbTest, statistics_t_id)
{
    uint8_t big_endian_raw_statistics_t_id[] = 
    {
        0xA1, 0xB2, 0xC3, 0xD4, //uint32_t total_count;
        0xA1, 0xB2, 0xC3, 0xD4, //uint32_t success_count;
        0xA1, 0xB2, 0xC3, 0xD4, //uint32_t error_count;
        0xA1, 0xB2, //uint16_t average_latency;
        0xA1, 0xB2, //uint16_t max_latency;
    };

    uint8_t little_endian_raw_statistics_t_id[] = 
    {
        0xD4, 0xC3, 0xB2, 0xA1, //uint32_t total_count;
        0xD4, 0xC3, 0xB2, 0xA1, //uint32_t success_count;
        0xD4, 0xC3, 0xB2, 0xA1, //uint32_t error_count;
        0xB2, 0xA1, //uint16_t average_latency;
        0xB2, 0xA1, //uint16_t max_latency;
    };

    EXPECT_EQ(sizeof(big_endian_raw_statistics_t_id),
              sizeof(statistics_t));
    EXPECT_EQ(sizeof(little_endian_raw_statistics_t_id),
              sizeof(statistics_t));

    messageHdr_type *pBigEndianMsgHdr = (messageHdr_type *)big_endian_raw_statistics_t_id;
    messageHdr_type *pLittleEndianMsgHdr = (messageHdr_type *)little_endian_raw_statistics_t_id;
    pBigEndianMsgHdr ->msgType = htons(statistics_t_id);
    pLittleEndianMsgHdr->msgType = (statistics_t_id);

    Gcci_EndianH2N(little_endian_raw_statistics_t_id, sizeof(statistics_t));

    EXPECT_EQ(0, memcmp(big_endian_raw_statistics_t_id,
                        little_endian_raw_statistics_t_id,
                        sizeof(little_endian_raw_statistics_t_id)));
}

