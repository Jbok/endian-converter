    messageHdr_type *pLittleEndianMsgHdr = (messageHdr_type *)little_endian_raw_complex_data_t_id;
    pBigEndianMsgHdr ->msgType = htons(complex_data_t_id);
    pLittleEndianMsgHdr->msgType = (complex_data_t_id);

    Gcci_EndianH2N(little_endian_raw_complex_data_t_id, sizeof(complex_data_t));

    EXPECT_EQ(0, memcmp(big_endian_raw_complex_data_t_id,
                        little_endian_raw_complex_data_t_id,
                        sizeof(little_endian_raw_complex_data_t_id)));
}

TEST(GcciEndianConverterDfcbTest, device_config_t_id)
{
    uint8_t big_endian_raw_device_config_t_id[] = 
    {
        0xA1, 0xB2, 0xC3, 0xD4, //uint32_t config_id;
        0xA1, 0xB2, //uint16_t config_version;
        0xA1, 0xB2, 0xC3, 0xD4, //uint32_t flags;
        0xA1, 0xB2, //uint16_t priority;
    };

    uint8_t little_endian_raw_device_config_t_id[] = 
    {
        0xD4, 0xC3, 0xB2, 0xA1, //uint32_t config_id;
        0xB2, 0xA1, //uint16_t config_version;
        0xD4, 0xC3, 0xB2, 0xA1, //uint32_t flags;
        0xB2, 0xA1, //uint16_t priority;
    };

    EXPECT_EQ(sizeof(big_endian_raw_device_config_t_id),
              sizeof(device_config_t));
    EXPECT_EQ(sizeof(little_endian_raw_device_config_t_id),
              sizeof(device_config_t));

    messageHdr_type *pBigEndianMsgHdr = (messageHdr_type *)big_endian_raw_device_config_t_id;
    messageHdr_type *pLittleEndianMsgHdr = (messageHdr_type *)little_endian_raw_device_config_t_id;
    pBigEndianMsgHdr ->msgType = htons(device_config_t_id);
    pLittleEndianMsgHdr->msgType = (device_config_t_id);

    Gcci_EndianH2N(little_endian_raw_device_config_t_id, sizeof(device_config_t));

    EXPECT_EQ(0, memcmp(big_endian_raw_device_config_t_id,
                        little_endian_raw_device_config_t_id,
                        sizeof(little_endian_raw_device_config_t_id)));
}

