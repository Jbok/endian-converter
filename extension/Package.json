{
  "name": "excel-copy",
  "displayName": "Excel 표 형식으로 복사",
  "description": "VSCode에서 선택한 텍스트를 엑셀/메신저 표 형식으로 클립보드에 복사",
  "version": "0.1.0",
  "engines": { "vscode": "^1.75.0" },
  "categories": ["Other"],
  "activationEvents": [],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "excelCopy.copyAsTable",
        "title": "Excel 표 형식으로 복사",
        "category": "ExcelCopy"
      }
    ],
    "keybindings": [
      {
        "command": "excelCopy.copyAsTable",
        "key": "ctrl+shift+e",
        "mac": "cmd+shift+e",
        "when": "editorTextFocus && editorHasSelection"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "excelCopy.copyAsTable",
          "when": "editorHasSelection",
          "group": "9_cutcopypaste@1"
        }
      ]
    }
  }
}
